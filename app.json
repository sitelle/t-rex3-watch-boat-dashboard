{
  "configVersion": "v3",
  "app": {
    "appId": 24767,
    "appName": "Boat Dashboard",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "0.1.0"
    },
    "icon": "icon.png",
    "vender": "zepp",
    "description": "Displays the boat instant speed from a Signal K server."
  },
  "permissions": [
    "data:os.device.info",
    "device:os.local_storage"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "4.0",
      "target": "4.0",
      "minVersion": "4.0"
    }
  },
  "debug": true,
  "targets": {
    "gt": {
      "module": {
        "page": {
          "pages": [
            "page/gt/home/index.page"
          ]
        },
        "setting": {
          "path": "setting/index"
        },
        "app-side": {
          "path": "app-side/index"
        }
      },
      "platforms": [
        {
          "st": "r"
        },
        {
          "st": "s"
        }
      ],
      "designWidth": 480
    }
  },
  "i18n": {
    "en-US": {
      "appName": "Boat Dashboard"
    },
    "fr-FR": {
      "appName": "Boat Dashboard"
    }
  },
  "defaultLanguage": "fr-FR"
}
